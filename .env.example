# Read allowlist — JIDs visible to read tools (list_messages, list_chats, etc.)
# Format: comma-separated. Empty = permissive (install-time discovery mode).
# Group JIDs end @g.us; 1:1 JIDs end @s.whatsapp.net.
WHATSAPP_ALLOWED_JIDS=

# Send allowlist — JIDs allowed as send_message/send_file/send_audio_message recipients.
# Format: comma-separated. Empty = block all sends (security default — opposite of read).
# Independent from read allowlist; a JID can be in either, both, or neither.
WHATSAPP_SEND_ALLOWED_JIDS=

# Bearer token used by Caddy reverse proxy (token B in two-token model).
WHATSAPP_MCP_TOKEN_B=
